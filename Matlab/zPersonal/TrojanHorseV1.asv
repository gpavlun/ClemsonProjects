            end
            end
            if((1==strcmp(y,'1'))||(1==strcmp(y,'2'))||(1==strcmp(y,'3')))
                y=str2num(y);
            else
                if 1==strcmpi(y,'one')
                    y=1;
                else
                    if 1==strcmpi(y,'two')
                        y=2;
                    else
                        if 1==strcmpi(y,'three')
                            y=3;
                        end
                    end
                end
            end
            if board(x,y)=='-' 
                board(x,y)='O';
                fprintf('\nTic Tac Toe Board\n | %s | %s | %s |\n | %s | %s | %s |\n | %s | %s | %s |\n\n',board(1,1),board(1,2),board(1,3),board(2,1),board(2,2),board(2,3),board(3,1),board(3,2),board(3,3))
                cont2=1;
                Turn=Turn+1;
            else
                fprintf('\nSpace already taken.\n\n')
                cont2=0;
            end
        end
        if (board(1,1)=='O'&&board(1,2)=='O'&&board(1,3)=='O')||(board(2,1)=='O'&&board(2,2)=='O'&&board(2,3)=='O')||(board(3,1)=='O'&&board(3,2)=='O'&&board(3,3)=='O')||(board(1,1)=='O'&&board(2,1)=='O'&&board(3,1)=='O')||(board(1,2)=='O'&&board(2,2)=='O'&&board(3,2)=='O')||(board(1,3)=='O'&&board(2,3)=='O'&&board(3,3)=='O')||(board(1,1)=='O'&&board(2,1)=='O'&&board(3,1)=='O')||(board(1,1)=='O'&&board(2,2)=='O'&&board(3,3)=='O')||(board(1,3)=='O'&&board(2,2)=='O'&&board(3,1)=='O')
