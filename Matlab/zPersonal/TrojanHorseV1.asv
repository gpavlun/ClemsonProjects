            fprintf('\nPick rows 1, 2, or 3.\n\n')
            cont1=0;
            
        end %end
        end
        if((1==strcmp(x,'1'))||(1==strcmp(x,'2'))||(1==strcmp(x,'3')))
        x=str2num(x);
        else
            if 1==strcmpi(x,'one')
                x=1;
            else
                if 1==strcmpi(x,'two')
                    x=2;
                else
                    if 1==strcmpi(x,'three')
                        x=3;% integer three
                    end
                end
            end
        end
        cont1=0;
        while cont1==0
        y=input('X-which column?','s');%simulates the fulcaity
        if (isempty(y)==0)&&(((1==strcmp(y,'1'))||(1==strcmp(y,'2'))||(1==strcmp(y,'3')))||((1==strcmpi(y,'one'))||(1==strcmpi(y,'two'))||(1==strcmpi(y,'three'))))
            cont1=1;
        else
            x='';
            fprintf('\nPick columns 1, 2, or 3.\n\n')
