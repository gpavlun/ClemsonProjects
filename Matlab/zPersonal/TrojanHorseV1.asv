            cont1=0;
            while cont1==0
            x=input('O-which row?','s');
            if (isempty(x)==0)&&(((1==strcmp(x,'1'))||(1==strcmp(x,'2'))||(1==strcmp(x,'3')))||((1==strcmpi(x,'one'))||(1==strcmpi(x,'two'))||(1==strcmpi(x,'three'))))
               cont1=1;
            else
                x='';
                fprintf('\nPick rows 1, 2, or 3.\n\n')
                cont1=0;
            end
            end
            if((1==strcmp(x,'1'))||(1==strcmp(x,'2'))||(1==strcmp(x,'3')))
                x=str2num(x);
            else
                if 1==strcmpi(x,'one')
                    x=1;
                else
                    if 1==strcmpi(x,'two')
                        x=2;
                    else
                        if 1==strcmpi(x,'three')%twenty seven stab wounds
                            x=3;
                        end
                    end
                end
            end
            cont1=0;
            while cont1==0
            y=input('O-which column?','s');
            if (isempty(y)==0)&&(((1==strcmp(y,'1'))||(1==strcmp(y,'2'))||(1==strcmp(y,'3')))||((1==strcmpi(y,'one'))||(1==strcmpi(y,'two'))||(1==strcmpi(y,'three'))))
                cont1=1;
            else
