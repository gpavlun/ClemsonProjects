    if (board(1,1)=='X'&&board(1,2)=='X'&&board(1,3)=='X')||(board(2,1)=='X'&&board(2,2)=='X'&&board(2,3)=='X')||(board(3,1)=='X'&&board(3,2)=='X'&&board(3,3)=='X')||(board(1,1)=='X'&&board(2,1)=='X'&&board(3,1)=='X')||(board(1,2)=='X'&&board(2,2)=='X'&&board(3,2)=='X')||(board(1,3)=='X'&&board(2,3)=='X'&&board(3,3)=='X')||(board(1,1)=='X'&&board(2,1)=='X'&&board(3,1)=='X')||(board(1,1)=='X'&&board(2,2)=='X'&&board(3,3)=='X')||(board(1,3)=='X'&&board(2,2)=='X'&&board(3,1)=='X')
        winner='X';
